generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(cuid())
  supabaseUserId String     @unique
  email          String     @unique
  age            Int?
  gender         String?
  resumeUrl      String?
  createdAt      DateTime   @default(now())
  firstName      String
  lastName       String
  favorites      Favorite[]
}

model Favorite {
  id          String @id @default(cuid())
  jobId       String
  userId      String
  category    String
  companyName String
  description String
  maxSalary   Int?
  minSalary   Int?
  title       String
  redirectUrl String?
  user        User   @relation(fields: [userId], references: [id])

  @@unique([userId, jobId])
}
